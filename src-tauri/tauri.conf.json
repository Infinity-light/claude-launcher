{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Launcher",
  "version": "0.1.0",
  "identifier": "com.yourcompany.claude-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Launcher",
        "width": 1000,
        "height": 800,
        "minWidth": 900,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": null
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
